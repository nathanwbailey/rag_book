# Required only for querying (the agent calls the LLM via OpenRouter).
# Ingestion does NOT need this.
OPENROUTER_API_KEY=

# Optional: override the model. Must be a FREE slug that supports tool calling,
# from https://openrouter.ai/models?max_price=0
# (default: meta-llama/llama-3.3-70b-instruct:free)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
